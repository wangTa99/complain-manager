    <select id="selectComplaintTimeoutList"
            resultType="com.wt.complaint.manage.infrastructure.model.ComplaintOrderDO">
        SELECT /*master*/
        <include refid="Base_Column_List"/>
        FROM complaint_order
        WHERE
        (
        (upgrade_time BETWEEN DATE_SUB(NOW(), INTERVAL 24 HOUR) AND DATE_SUB(NOW(), INTERVAL 20 HOUR))
        OR
        (upgrade_time BETWEEN DATE_SUB(NOW(), INTERVAL 72 HOUR) AND DATE_SUB(NOW(), INTERVAL 60 HOUR))
        )
    </select>
    <select id="selectFirstResponseToTimeoutList"
            resultType="com.wt.complaint.manage.infrastructure.model.ComplaintOrderDO">
        SELECT
        <include refid="Base_Column_List"/>
        FROM complaint_order
        WHERE
        status in
        <foreach collection="statusList" item="item" open="(" close=")" separator=",">
            #{item}
        </foreach>
        AND
        (
        (upgrade_time BETWEEN DATE_SUB(NOW(), INTERVAL 24 HOUR) AND DATE_SUB(NOW(), INTERVAL 20
        HOUR))
        )
        order by id asc
    </select>
    <select id="selectFinishToTimeoutList"
            resultType="com.wt.complaint.manage.infrastructure.model.ComplaintOrderDO">
        SELECT
        <include refid="List_Base_Column"/>
        FROM complaint_order co
        LEFT JOIN complaint_tag ct ON co.complaint_no = ct.complaint_no
        WHERE
        co.status != 90
        AND
        co.upgrade_time BETWEEN DATE_SUB(NOW(), INTERVAL 72 HOUR) AND DATE_SUB(NOW(), INTERVAL 60 HOUR)
        AND
        ct.tag_type != 'FINISH_72H_ASSESSMENT_FREE'
        AND
        ct.is_deleted = 0
        order by co.id asc
    </select>

    <select id="selectUnFinishedToTimeoutList"
            resultType="com.wt.complaint.manage.infrastructure.model.ComplaintOrderDO">
        SELECT
        <include refid="List_Base_Column"/>
        FROM complaint_order co
        WHERE
        co.status in (1, 30, 50, 70)
        AND
        co.upgrade_time BETWEEN DATE_SUB(NOW(), INTERVAL 180 DAY) AND DATE_SUB(NOW(), INTERVAL 15 DAY)
        order by co.id asc
    </select>

