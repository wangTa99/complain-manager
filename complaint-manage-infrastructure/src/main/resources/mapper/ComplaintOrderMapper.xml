    <select id="selectPageByParam"
            resultType="com.wt.complaint.manage.infrastructure.model.ComplaintOrderDO">
        select
        <include refid="List_Base_Column"/>
        from complaint_order co
        <if test="params.tagList != null and params.tagList.size() > 0">
            left join complaint_tag ct on co.complaint_no = ct.complaint_no
        </if>
        <if test="params.padRelateListGroup != null and params.padRelateListGroup.tagList != null and params.padRelateListGroup.tagList.size() > 0">
            left join complaint_relation_closing_tag cr on co.complaint_no = cr.complaint_no
        </if>
        <include refid="selectByParamCondition"/>
        order by co.id desc
        limit #{params.start,jdbcType=INTEGER},#{params.pageSize,jdbcType=INTEGER}
    </select>

    <select id="countByParam" resultType="java.lang.Integer">
        select
        count(co.id)
        from complaint_order co
        <if test="params.tagList!= null and params.tagList.size() > 0">
            left join complaint_tag ct on co.complaint_no = ct.complaint_no
        </if>
        <if test="params.padRelateListGroup != null and params.padRelateListGroup.tagList != null and params.padRelateListGroup.tagList.size() > 0">
            left join complaint_relation_closing_tag cr on co.complaint_no = cr.complaint_no
        </if>
        <include refid="selectByParamCondition"/>
    </select>

    <sql id="selectByParamCondition">
        <where>
            <if test="params.orgId != null and params.orgId != ''">
                and co.org_id = #{params.orgId,jdbcType=VARCHAR}
            </if>
            <if test="params.statusList != null and params.statusList.size() > 0">
                and co.status in
                <foreach collection="params.statusList" item="item" index="index" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="params.complaintNo != null and params.complaintNo != '' ">
                and co.complaint_no = #{params.complaintNo,jdbcType=VARCHAR}
            </if>
            <if test="params.contactPhoneSuffix != null and params.contactPhoneSuffix != ''">
                and co.contact_phone_sufix = #{params.contactPhoneSuffix,jdbcType=VARCHAR}
            </if>
            <if test="params.vinSuffix != null and params.vinSuffix != ''">
                and co.vin_sufix = #{params.vinSuffix,jdbcType=VARCHAR}
            </if>
            <if test="params.carNo != null and params.carNo != ''">
                and co.car_no = #{params.carNo,jdbcType=VARCHAR}
            </if>
            <if test="params.operatorMid != null">
                and co.operator_mid = #{params.operatorMid,jdbcType=BIGINT}
            </if>
            <if test="params.createTimeStart != null and params.createTimeStart !=''">
                and co.create_time <![CDATA[>=]]> #{params.createTimeStart, jdbcType=VARCHAR}
            </if>
            <if test="params.createTimeEnd != null and params.createTimeEnd != ''">
                and co.create_time <![CDATA[<=]]> #{params.createTimeEnd, jdbcType=VARCHAR}
            </if>
            <if test="params.finishTimeStart != null and params.finishTimeStart != ''">
                and co.finish_time <![CDATA[>=]]> #{params.finishTimeStart, jdbcType=VARCHAR}
            </if>
            <if test="params.finishTimeEnd != null and params.finishTimeEnd != ''">
                and co.finish_time <![CDATA[<=]]> #{params.finishTimeEnd, jdbcType=VARCHAR}
            </if>
            <if test="params.firstResponseTimeStart != null and params.firstResponseTimeStart != ''">
                and co.first_response_time <![CDATA[>=]]> #{params.firstResponseTimeStart, jdbcType=VARCHAR}
            </if>
            <if test="params.firstResponseTimeEnd != null and params.firstResponseTimeEnd != ''">
                and co.first_response_time <![CDATA[<=]]> #{params.firstResponseTimeEnd, jdbcType=VARCHAR}
            </if>
            <if test="params.complaintType != null">
                and co.complaint_type = #{params.complaintType, jdbcType=INTEGER}
            </if>
            <if test="params.vin != null and params.vin != '' ">
                and co.vid = #{params.vin,jdbcType=VARCHAR}
            </if>
            <if test="params.contactPhone != null and params.contactPhone != ''">
                and co.contact_phone_md5 = #{params.contactPhone,jdbcType=VARCHAR}
            </if>
            <if test="params.cityList != null and params.cityList.size() > 0">
                and co.city_id in
                <foreach collection="params.cityList" item="item" index="index" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="params.orgIdList != null and params.orgIdList.size() > 0">
                and co.org_id in
                <foreach collection="params.orgIdList" item="item" index="index" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="params.zoneIdList != null and params.zoneIdList.size() > 0">
                and co.zone_id in
                <foreach collection="params.zoneIdList" item="item" index="index" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="params.problemDesc != null and params.problemDesc != ''">
                and co.problem_desc LIKE CONCAT('%', #{params.problemDesc,jdbcType=VARCHAR}, '%')
            </if>
            <if test="params.reminderTimes != null and params.reminderTimes != ''">
                <choose>
                    <when test="params.reminderTimes >=3">
                        and co.reminder_times <![CDATA[>=]]> #{params.reminderTimes,jdbcType=INTEGER}
                    </when>
                    <otherwise>
                        and co.reminder_times = #{params.reminderTimes,jdbcType=INTEGER}
                    </otherwise>
                </choose>
            </if>
            <if test="params.riskLevelList != null and params.riskLevelList.size() > 0">
                and co.risk_level in
                <foreach collection="params.riskLevelList" item="item" index="index" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <!-- Õ«óĶ»ēõĖēµ£¤Õ║¤Õ╝ā’╝ÜķŚ©Õ║Śµś»ÕÉ”µ£ēĶ┤ŻõĖŹÕåŹõĮ£õĖ║ńŁøķĆēµØĪõ╗?-->
            <if test="params.responsibility != null">
                and co.responsibility = #{params.responsibility, jdbcType=INTEGER}
            </if>
            <if test="params.reviewed != null">
                and co.reviewed = #{params.reviewed, jdbcType=INTEGER}
            </if>
            <if test="params.createSource != null">
                and co.create_source = #{params.createSource,jdbcType=INTEGER}
            </if>
            <if test="params.mediaInvolved != null">
                and co.media_involved = #{params.mediaInvolved,jdbcType=INTEGER}
            </if>
            <if test="params.afterSaleWorkbenchPermissionGroup != null">
                <choose>
                    <when test="params.afterSaleWorkbenchPermissionGroup.afterSaleWorkbenchPermissionType != null and params.afterSaleWorkbenchPermissionGroup.afterSaleWorkbenchPermissionType == 1">
                        and co.zone_id in
                        <foreach collection="params.afterSaleWorkbenchPermissionGroup.bigZonePositionsInfoList" item="item" index="index" open="(" separator="," close=")">
                            #{item.zoneId}
                        </foreach>
                    </when>
                    <when test="params.afterSaleWorkbenchPermissionGroup.afterSaleWorkbenchPermissionType != null and params.afterSaleWorkbenchPermissionGroup.afterSaleWorkbenchPermissionType == 2">
                        and co.little_zone_id in
                        <foreach collection="params.afterSaleWorkbenchPermissionGroup.littleZonePositionsInfoList" item="item" index="index" open="(" separator="," close=")">
                            #{item.zoneId}
                        </foreach>
                    </when>
                    <otherwise>
                    </otherwise>
                </choose>
            </if>
            <if test="params.padRelateListGroup != null">
                and ((co.create_time <![CDATA[>=]]> #{params.padRelateListGroup.createTimeStart} and co.create_time <![CDATA[<=]]> #{params.padRelateListGroup.createTimeEnd}
                and co.status in
                <foreach collection="params.padRelateListGroup.inProgressStatus" item="item" index="index" open="(" separator="," close=")">
                    #{item}
                </foreach>
                ) or (cr.closing_tag_name_link in
                <foreach collection="params.padRelateListGroup.tagList" item="item" index="index" open="(" separator="," close=")">
                    #{item}
                </foreach> and co.status in
                <foreach collection="params.padRelateListGroup.completeStatus" item="item" index="index" open="(" separator="," close=")">
                    #{item}
                </foreach>
                and cr.is_deleted = 0))
            </if>
            <if test="params.tagList != null and params.tagList.size() > 0">
                and (ct.tag_type in
                <foreach collection="params.tagList" item="item" index="index" open="(" separator="," close=")">
                    #{item}
                </foreach>
                and ct.is_deleted = 0)
            </if>
            <if test="params.tab != null">
                <choose>
                    <when test="params.tab == 1">
                    </when>
                    <when test="params.tab == 2">
                        and co.status = #{params.statusList[0]}
                    </when>
                    <when test="params.tab == 3">
                        and co.status in
                        <foreach collection="params.statusList" item="status" open="(" close=")" separator=",">
                            #{status}
                        </foreach>
                    </when>
                    <when test="params.tab == 4">
                        and (
                        (co.upgrade_time BETWEEN DATE_SUB(NOW(), INTERVAL 24 HOUR) AND DATE_SUB(NOW(), INTERVAL 20 HOUR) and co.status in
                        <foreach collection="params.conditionGroups[0].statusList" item="status" open="(" close=")" separator=",">
                            #{status}
                        </foreach>)
                        or
                        (co.upgrade_time  BETWEEN DATE_SUB(NOW(), INTERVAL 72 HOUR) AND DATE_SUB(NOW(), INTERVAL 60 HOUR) and co.status in
                        <foreach collection="params.conditionGroups[2].statusList" item="status" open="(" close=")" separator=",">
                            #{status}
                        </foreach>)
                        )
                    </when>
                    <when test="params.tab == 5">
                        and co.status = #{params.statusList[0]}
                    </when>

                    <when test="params.tab == 6">
                        and co.only_view = #{params.onlyView}
                    </when>
                    <!-- Õ«óĶ»ēõĖēµ£¤’╝ÜÕŠģÕżŹńøś’╝īµ£ŹÕŖĪµŖĢĶ»ēµ£¬ÕżŹńøśÕŹ?reviewed=0 -->
                    <when test="params.tab == 8">
                        and co.reviewed = 0
                    </when>
                </choose>
            </if>
            <if test="params.onlyShowMyCompositeOrder==true">
                and co.operator_mid = #{params.mid, jdbcType=BIGINT}
            </if>
            <if test="params.testTag != null">
                and co.test_tag = #{params.testTag,jdbcType=INTEGER}
            </if>
        </where>
    </sql>

