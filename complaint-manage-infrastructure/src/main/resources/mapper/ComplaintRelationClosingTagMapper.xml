<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wt.complaint.manage.infrastructure.mapper.ComplaintRelationClosingTagMapper">

    <resultMap id="BaseResultMap"
               type="com.wt.complaint.manage.infrastructure.model.ComplaintRelationClosingTagDO">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="complaintNo" column="complaint_no" jdbcType="VARCHAR"/>
        <result property="closingTagIdLink" column="closing_tag_id_link" jdbcType="VARCHAR"/>
        <result property="closingTagNameLink" column="closing_tag_name_link" jdbcType="VARCHAR"/>
        <result property="isDeleted" column="is_deleted" jdbcType="TINYINT"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id
        ,complaint_no,closing_tag_id_link,
        closing_tag_name_link,is_deleted,create_time,
        update_time
    </sql>

    <insert id="insertSelective"
            parameterType="com.wt.complaint.manage.infrastructure.model.ComplaintRelationClosingTagDO">
        insert into complaint_relation_closing_tag
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="complaintNo != null and complaintNo!= ''">
                complaint_no,
            </if>
            <if test="closingTagIdLink != null and closingTagIdLink != ''">
                closing_tag_id_link,
            </if>
            <if test="closingTagNameLink != null and closingTagNameLink != ''">
                closing_tag_name_link,
            </if>
            <if test="isDeleted != null">
                is_deleted,
            </if>
            <if test="createTime != null">
                create_time,
            </if>
            <if test="updateTime != null">
                update_time,
            </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">
                #{id},
            </if>
            <if test="complaintNo != null and complaintNo != ''">
                #{complaintNo},
            </if>
            <if test="closingTagIdLink != null and closingTagIdLink != ''">
                #{closingTagIdLink},
            </if>
            <if test="closingTagNameLink != null and closingTagNameLink != ''">
                #{closingTagNameLink},
            </if>
            <if test="isDeleted != null">
                #{isDeleted},
            </if>
            <if test="createTime != null">
                #{createTime},
            </if>
            <if test="updateTime != null">
                #{updateTime},
            </if>
        </trim>
    </insert>
    <insert id="batchInsertSelective" parameterType="java.util.List">
        insert into complaint_relation_closing_tag
        (complaint_no,closing_tag_id_link,closing_tag_name_link, is_deleted,create_time)
        values
        <foreach collection="list" item="item" separator=",">

            (#{item.complaintNo},

            #{item.closingTagIdLink},

            #{item.closingTagNameLink},

            #{item.isDeleted},

            #{item.createTime})

        </foreach>
    </insert>

    <select id="selectByComplaintNo"
            resultType="com.wt.complaint.manage.infrastructure.model.ComplaintRelationClosingTagDO">
        select
        <include refid="Base_Column_List"/>
        from complaint_relation_closing_tag
        where complaint_no = #{complaintNo, jdbcType=VARCHAR}
        and is_deleted = 0
        order by id asc
    </select>

    <update id="deleteByComplaintNo">
        update complaint_relation_closing_tag
        set is_deleted  = 1,
            update_time = now()
        where complaint_no = #{complaintNo, jdbcType=VARCHAR}
    </update>


</mapper>
