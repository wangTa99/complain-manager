    <select id="selectListByCondition"
            resultType="com.wt.complaint.manage.infrastructure.model.DeliverComplaintDO">
        SELECT
        <if test="useMaster != null and useMaster">
            /*master*/
        </if>
        <include refid="Base_Column_List"/>
        FROM deliver_retail_complaint_order
        <include refid="Common_Where_Condition"/>
        <!--数据权限-->
        <include refid="Common_Data_Permission_Condition"/>
        ORDER BY  reminder_times DESC, risk_level DESC,create_time DESC
        <if test="offset != null and pageSize != null">
            LIMIT #{offset}, #{pageSize}
        </if>

    </select>


    <select id="selectCountByCondition" resultType="java.lang.Long">
