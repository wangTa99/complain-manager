            </trim>
            <trim prefix="city_id = CASE" suffix="END,">
                <foreach collection="updateList" item="item">
                    <if test="item.cityId != null">
                        WHEN dr_no = #{item.drNo,jdbcType=VARCHAR} THEN #{item.cityId,jdbcType=INTEGER}
                    </if>
                </foreach>
                ELSE city_id
            </trim>
        </trim>
        WHERE dr_no IN
        <foreach collection="updateList" item="item" open="(" separator="," close=")">
            #{item.drNo,jdbcType=VARCHAR}
        </foreach>
    </update>

</mapper>
