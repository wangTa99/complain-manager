    <update id="batchUpdateByDrNo">
        UPDATE deliver_retail_complaint_order
        <trim prefix="SET" suffixOverrides=",">
            <trim prefix="customer_service_mid = CASE" suffix="END,">
                <foreach collection="updateParamList" item="updateParam">
                    <if test="updateParam.customerServiceMid != null">
                        WHEN dr_no = #{updateParam.drNo,jdbcType=VARCHAR} THEN #{updateParam.customerServiceMid,jdbcType=BIGINT}
                    </if>
                </foreach>
                ELSE customer_service_mid
            </trim>
        </trim>
        WHERE dr_no IN
        <foreach collection="updateParamList" item="updateParam" open="(" separator="," close=")">
            #{updateParam.drNo,jdbcType=VARCHAR}
        </foreach>
    </update>

    <select id="selectFirstResponseToTimeoutList"
            resultType="com.wt.complaint.manage.infrastructure.model.DeliverComplaintDO">
        SELECT
        <include refid="Base_Column_List"/>
        FROM deliver_retail_complaint_order
        WHERE source = 0
        AND order_status = 10
        AND expected_first_response_time BETWEEN NOW() AND DATE_ADD(NOW(), INTERVAL 1 HOUR)
        order by id asc
    </select>

    <select id="selectFinishToTimeoutList"
            resultType="com.wt.complaint.manage.infrastructure.model.DeliverComplaintDO">
        SELECT
        <include refid="Base_Column_List"/>
        FROM deliver_retail_complaint_order
        WHERE source = 0
        AND order_status IN (10, 20)
        AND expected_finish_time BETWEEN NOW() AND DATE_ADD(NOW(), INTERVAL 12 HOUR)
        order by id asc
    </select>

