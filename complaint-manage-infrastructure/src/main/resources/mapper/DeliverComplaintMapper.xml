        WHERE super_ticket_no IN
        <foreach collection="stNoList" item="stNo" open="(" separator="," close=")">
            #{stNo}
        </foreach>
    </select>

    <sql id="Common_Data_Permission_Condition">
        <!--数据权限-->
        <if test="permissionZoneId != null and permissionZoneId.size() > 0">
            AND zone_id IN
            <foreach collection="permissionZoneId" item="item" open="(" separator="," close=")">
                #{item}
            </foreach>
        </if>
        <if test="permissionLittleZoneId != null and permissionLittleZoneId.size() > 0">
            AND little_zone_id IN
            <foreach collection="permissionLittleZoneId" item="item" open="(" separator="," close=")">
                #{item}
            </foreach>
        </if>
        <if test="permissionOrgId != null and permissionOrgId.size() > 0">
            AND org_id IN
            <foreach collection="permissionOrgId" item="item" open="(" separator="," close=")">
                #{item}
            </foreach>
        </if>
        <if test="permissionOperatorMid != null and permissionOperatorMid.size() > 0">
            AND operator_mid IN
            <foreach collection="permissionOperatorMid" item="item" open="(" separator="," close=")">
                #{item}
            </foreach>
        </if>
    </sql>


    <sql id="Common_Where_Condition">
        <where>
            source = 0
            <if test="orgIds != null and orgIds.size() > 0">
                AND org_id IN
                <foreach collection="orgIds" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="testTag != null">
                AND test_tag = #{testTag}
            </if>
            <if test="drNo != null and drNo != ''">
                AND dr_no = #{drNo}
            </if>
            <if test="tradeOrderId != null and tradeOrderId != ''">
                AND trade_order_id = #{tradeOrderId}
            </if>
            <if test="contactNameMd5 != null and contactNameMd5 != ''">
                AND contact_name_md5 = #{contactNameMd5}
            </if>
            <if test="contactPhoneMd5 != null and contactPhoneMd5 != ''">
                AND contact_phone_md5 = #{contactPhoneMd5}
            </if>
            <if test="riskLevel != null and riskLevel.size() > 0">
                AND risk_level IN
                <foreach collection="riskLevel" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="lastComplaintSceneId != null and lastComplaintSceneId.size() > 0">
                AND last_complaint_scene_id IN
                <foreach collection="lastComplaintSceneId" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="lastCategoryId != null and lastCategoryId.size() > 0">
                AND last_category_id IN
                <foreach collection="lastCategoryId" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="orderStatus != null and orderStatus.size() > 0">
                AND order_status IN
                <foreach collection="orderStatus" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="responsible != null and responsible.size() > 0">
                AND responsible IN
                <foreach collection="responsible" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="operatorPositionId != null and operatorPositionId.size() > 0">
                AND operator_position_id IN
                <foreach collection="operatorPositionId" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="operatorMid != null and operatorMid.size() > 0">
                AND operator_mid IN
                <foreach collection="operatorMid" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="reminderTimes != null and reminderTimes.size() > 0">
                AND ( reminder_times IN
                <foreach collection="reminderTimes" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
                <if test="reminderTimes != null and reminderTimes.contains(2)">
                    OR reminder_times <![CDATA[>]]> 2
                </if>
                )
            </if>
            <if test="firstResponseTag != null">
                AND first_response_tag = #{firstResponseTag}
            </if>
            <if test="finishTag != null">
                AND finish_tag = #{finishTag}
            </if>
            <if test="createTimeStart != null and createTimeStart != ''">
                AND create_time <![CDATA[>=]]> #{createTimeStart}
            </if>
            <if test="createTimeEnd != null and createTimeEnd != ''">
                AND create_time <![CDATA[<=]]> #{createTimeEnd}
            </if>
            <if test="realFirstResponseTimeStart != null and realFirstResponseTimeStart != ''">
                AND real_first_response_time <![CDATA[>=]]> #{realFirstResponseTimeStart}
            </if>
            <if test="realFirstResponseTimeEnd != null and realFirstResponseTimeEnd != ''">
                AND real_first_response_time <![CDATA[<=]]> #{realFirstResponseTimeEnd}
            </if>
            <if test="realFinishTimeStart != null and realFinishTimeStart != ''">
                AND real_finish_time <![CDATA[>=]]> #{realFinishTimeStart}
            </if>
            <if test="realFinishTimeEnd != null and realFinishTimeEnd != ''">
                AND real_finish_time <![CDATA[<=]]> #{realFinishTimeEnd}
            </if>
            <if test="onlyUnfinished != null and onlyUnfinished">
                AND responsible in (0, 3)
            </if>
        </where>
    </sql>

    <select id="selectStatisticsItems"
            resultType="com.wt.complaint.manage.domain.bo.DeliverStatisticsItemBO">
        SELECT
            COUNT(CASE WHEN order_status = 10 THEN 1 ELSE NULL END) AS pendingFirstResponseCount,
            COUNT(CASE WHEN order_status = 20 THEN 1 ELSE NULL END) AS handlingCount,
            COUNT(CASE WHEN responsible = 3 AND order_status = 50 THEN 1 ELSE NULL END) AS pendingResponsibilityCount,
            COUNT(CASE WHEN reminder_times > 0 and order_status!= 50 THEN 1 ELSE NULL END) AS remindCount,
            COUNT(CASE WHEN order_status = 10 and first_response_tag = 1 THEN 1 ELSE NULL END) AS firstResponseTimeoutCount,
            COUNT(CASE WHEN order_status != 50 and finish_tag = 1 THEN 1 ELSE NULL END) AS finishTimeoutCount
        FROM deliver_retail_complaint_order
        <where>
            source = 0
            <if test="orgIds != null and orgIds.size() > 0">
                AND org_id IN
                <foreach collection="orgIds" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="testTag != null">
                AND test_tag = #{testTag}
            </if>
            <!--数据权限-->
            <include refid="Common_Data_Permission_Condition"/>
        </where>


    </select>
    <select id="selectDetail"
            resultType="com.wt.complaint.manage.infrastructure.model.DeliverComplaintDO">
        SELECT
        <include refid="Base_Column_List"/>
        FROM deliver_retail_complaint_order
