        count(*)
        FROM deliver_retail_complaint_order
        <include refid="Common_Where_Condition"/>
        <!--数据权限-->
        <include refid="Common_Data_Permission_Condition"/>
    </select>

    <select id="selectByDrNo" resultMap="BaseResultMap">
