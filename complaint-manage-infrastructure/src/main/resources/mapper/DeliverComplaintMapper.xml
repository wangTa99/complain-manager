        WHERE dr_no = #{drNo}
        LIMIT 1
    </select>

    <select id="selectByDrNoList" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM deliver_retail_complaint_order
        WHERE dr_no IN
        <foreach collection="drNoList" item="drNo" open="(" separator="," close=")">
            #{drNo}
        </foreach>
    </select>

    <select id="selectByStNoList" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List_Without_Text"/>
