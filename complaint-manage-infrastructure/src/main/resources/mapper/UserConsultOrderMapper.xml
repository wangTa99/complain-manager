    <select id="selectByParam" resultMap="BaseResultMap">
        select
        <if test = "master != null and master == true">/*master*/</if>
        <include refid="Base_Column_List"/>
        from user_consult_order
        <where>
            <if test="consultNoList != null and consultNoList.size > 0">
