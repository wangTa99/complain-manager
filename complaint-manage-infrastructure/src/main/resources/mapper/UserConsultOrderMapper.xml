    <select id="countPadPageByParam" resultType="long">
        SELECT COUNT(*)
        FROM user_consult_order
        <include refid="Pad_List_Where_Clause"/>
    </select>

    <!-- PADķøČÕö«ķĆÜ’╝ÜÕłåķĪĄµ¤źĶ»óÕłŚĶĪ© -->
    <select id="padPageByParam" resultMap="BaseResultMap">
