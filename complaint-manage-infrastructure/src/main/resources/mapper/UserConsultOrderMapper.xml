            </if>
            <if test="stNoList != null and stNoList.size > 0">
                super_ticket_no in
                <foreach collection="stNoList" item="item" separator="," open="(" close=")">
                    #{item}
                </foreach>
            </if>
            <if test="consultNo != null">and consult_no = #{consultNo}</if>
            <if test="superTicketNo != null">and super_ticket_no = #{superTicketNo}</if>
            <if test="consultType != null">and consult_type = #{consultType}</if>
            <if test="idempotentKey != null">and idempotent_key = #{idempotentKey}</if>
            <if test="vid != null">and vid = #{vid}</if>
