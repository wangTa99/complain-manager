        </if>
    </select>
    <select id="findList" resultType="com.wt.complaint.manage.domain.model.UserConsultOrderInfo">
        select
        <include refid="Base_Column_List"/>
        from user_consult_order
        <where>
            <if test="orgIdList != null and orgIdList.size() > 0">
                org_id IN
                <foreach collection="orgIdList" item="item" separator="," open="(" close=")">
                    #{item}
                </foreach>
            </if>

            <if test="consultStatusList != null and consultStatusList.size()>0">
                and order_status in
                <foreach collection="consultStatusList" item="item" open="(" close=")" separator=",">
                    #{item}
                </foreach>
            </if>

        </where>
    </select>

    <!-- PADķøČÕö«ķĆ?WHERE µØĪõ╗Č’╝Ükey  consult_no ń▓ŠńĪ«µÉ£ń┤ó/car_no ń▓ŠńĪ«µÉ£ń┤ó/vid µ©Īń│ŖÕī╣ķģŹ -->
    <sql id="Pad_List_Where_Clause">
        <where>
            <if test="orgIdList != null and orgIdList.size() > 0">
                org_id IN
                <foreach collection="orgIdList" item="item" separator="," open="(" close=")">
                    #{item}
                </foreach>
            </if>
            <if test="orderStatus != null">
                AND order_status = #{orderStatus}
            </if>
            <if test="operatorMid != null">
                AND operator_mid = #{operatorMid}
            </if>
            <if test="key != null and key != ''">
                AND (consult_no = #{key}
                  OR car_no  = #{key}
                  OR vin_sufix = #{key})
            </if>
        </where>
    </sql>

    <!-- Õö«ÕÉÄÕĘźõĮ£ÕÅ?WHERE µØĪõ╗Č -->
    <sql id="Web_List_Where_Clause">
        <where>
            <if test="orgIdList != null and orgIdList.size() > 0">
                org_id IN
                <foreach collection="orgIdList" item="item" separator="," open="(" close=")">
                    #{item}
                </foreach>
            </if>
            <if test="consultNo != null and consultNo != ''">
                AND consult_no = #{consultNo}
            </if>
            <if test="orderStatus != null">
                AND order_status = #{orderStatus}
            </if>
            <if test="consultType != null">
                AND consult_type = #{consultType}
            </if>
            <if test="handleResult != null">
                AND handle_result = #{handleResult}
            </if>
            <if test="vin != null and vin != ''">
                AND vin_sufix  = RIGHT(#{vin}, 6)
            </if>
            <if test="urgencyLevel != null">
                AND priority = #{urgencyLevel}
            </if>
            <if test="createTimeStart != null and createTimeStart != ''">
                and   create_time &gt;=  #{createTimeStart}
            </if>
            <if test="createTimeEnd != null and createTimeEnd != ''">
                and   create_time &lt;=  #{createTimeEnd}
            </if>
            <if test="finishTimeStart != null and finishTimeStart != ''">
                and   finish_time &gt;=  #{finishTimeStart}
            </if>
            <if test="finishTimeEnd != null and finishTimeEnd != ''">
                and   finish_time &lt;=  #{finishTimeEnd}
            </if>
        </where>
    </sql>

</mapper>
