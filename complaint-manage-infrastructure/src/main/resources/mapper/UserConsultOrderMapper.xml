    <select id="countStatisticsByOrgId" resultType="com.wt.complaint.manage.domain.model.ConsultStatusCountInfo">
        SELECT order_status AS orderStatus,COUNT(*) AS cnt
        FROM user_consult_order
        <where>
            <if test="orgId != null">
                org_id  = #{orgId}
            </if>
            <if test="mid != null">
                AND operator_mid = #{mid}
