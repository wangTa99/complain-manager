<mapper namespace="com.wt.complaint.manage.infrastructure.mapper.ComplaintAuditMapper">

    <resultMap id="BaseResultMap" type="com.wt.complaint.manage.infrastructure.model.ComplaintAuditDO">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="complaintNo" column="complaint_no" jdbcType="VARCHAR"/>
        <result property="vid" column="vid" jdbcType="VARCHAR"/>
        <result property="carNo" column="car_no" jdbcType="VARCHAR"/>
        <result property="orgId" column="org_id" jdbcType="VARCHAR"/>
        <result property="orgName" column="org_name" jdbcType="VARCHAR"/>
        <result property="zoneId" column="zone_id" jdbcType="VARCHAR"/>
        <result property="littleZoneId" column="little_zone_id" jdbcType="VARCHAR"/>
        <result property="contactNameC" column="contact_name_c" jdbcType="VARCHAR"/>
        <result property="contactPhoneC" column="contact_phone_c" jdbcType="VARCHAR"/>
        <result property="applyContent" column="apply_content" jdbcType="VARCHAR"/>
        <result property="auditType" column="audit_type" jdbcType="INTEGER"/>
        <result property="auditStatus" column="audit_status" jdbcType="INTEGER"/>
        <result property="auditMid" column="audit_mid" jdbcType="BIGINT"/>
        <result property="createMid" column="create_mid" jdbcType="BIGINT"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
        <result property="auditComment" column="audit_comment" jdbcType="VARCHAR"/>
