            <if test="applyContent != null">
                #{applyContent,jdbcType=VARCHAR},
            </if>
            <if test="auditType != null">
                #{auditType,jdbcType=INTEGER},
            </if>
            <if test="auditStatus != null">
                #{auditStatus,jdbcType=INTEGER},
            </if>
            <if test="auditMid != null">
                #{auditMid,jdbcType=BIGINT},
            </if>
            <if test="createMid != null">
                #{createMid,jdbcType=BIGINT},
            </if>
            <if test="createTime != null">
                #{createTime,jdbcType=TIMESTAMP},
            </if>
            <if test="updateTime != null">
                #{updateTime,jdbcType=TIMESTAMP},
            </if>
            <if test="auditComment != null">
                #{auditComment,jdbcType=VARCHAR},
            </if>
            <if test="contactPhoneMd5 != null">
                #{contactPhoneMd5,jdbcType=VARCHAR},
            </if>
            <if test="userAgreement != null">
                #{userAgreement,jdbcType=INTEGER},
            </if>
            <if test="vehicleRepaired != null">
                #{vehicleRepaired,jdbcType=INTEGER},
            </if>
            <if test="mediaInfo != null">
                #{mediaInfo,jdbcType=INTEGER},
            </if>
            <if test="currentNode != null">
                #{currentNode,jdbcType=INTEGER},
            </if>
        </trim>
    </insert>
    <select id="list" resultType="com.wt.complaint.manage.infrastructure.model.ComplaintAuditDO">
            select
            <include refid="Base_Column_List"></include>
            from complaint_audit au
            <where>
                <if test="complaintNo != null">
                    and au.complaint_no = #{complaintNo}
                </if>
                <if test="auditType != null">
                    and au.audit_type = #{auditType}
                </if>
                <if test="auditStatus != null">
                    and au.audit_status = #{auditStatus}
                </if>
            </where>

    </select>
    <select id="selectPreAndAfter"
            parameterType="com.wt.complaint.manage.domain.api.service.parameter.in.approve.ComplaintPreNextSoIn"
            resultType="java.lang.Long">
        select id from complaint_audit
        where id = (select min(id) from complaint_audit <include refid="selectPreAndAfterWhereDetailMin"/>)
        or id = (select max(id) from complaint_audit <include refid="selectPreAndAfterWhereDetailMax"/>)
        order by id desc
    </select>
    <select id="selectById"
            resultType="com.wt.complaint.manage.infrastructure.model.ComplaintAuditDO">
        select
        <include refid="Base_Column_List"/>
        from complaint_audit au
        where au.id = #{id, jdbcType=BIGINT}
    </select>
    <select id="selectByComplaintNo"
            resultType="com.wt.complaint.manage.infrastructure.model.ComplaintAuditDO">
        select
        <include refid="Base_Column_List"/>
        from complaint_audit au
        where au.complaint_no = #{complaintNo}
        and au.audit_type = #{auditType}
        order by au.id desc limit 1
    </select>

    <sql id="selectPreAndAfterWhereDetailMin">
        <where>
            <if test="auditStatus != null">
                and audit_status=#{auditStatus}
            </if>
            <if test="zoneIdList != null and zoneIdList.size() > 0">
                and zone_id in
                <foreach collection="zoneIdList" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="littleZoneIdList != null and littleZoneIdList.size() > 0">
                and little_zone_id in
                <foreach collection="littleZoneIdList" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="auditTypeList != null and auditTypeList.size() > 0">
                and audit_type in
                <foreach collection="auditTypeList" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <!-- 申请免责(3)按节点过滤：非申请免责或 current_node 在允许范围内 -->
            <if test="waiverCurrentNodeList != null and waiverCurrentNodeList.size() > 0">
                and (audit_type != 3 or current_node in
                <foreach collection="waiverCurrentNodeList" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
                )
            </if>
            and id <![CDATA[>]]> #{id} limit 1
        </where>
    </sql>

    <sql id="selectPreAndAfterWhereDetailMax">
        <where>
            <if test="auditStatus != null">
                and audit_status=#{auditStatus}
            </if>
            <if test="zoneIdList != null and zoneIdList.size() > 0">
                and zone_id in
                <foreach collection="zoneIdList" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="littleZoneIdList != null and littleZoneIdList.size() > 0">
                and little_zone_id in
                <foreach collection="littleZoneIdList" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="auditTypeList != null and auditTypeList.size() > 0">
                and audit_type in
                <foreach collection="auditTypeList" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <!-- 申请免责(3)按节点过滤：非申请免责或 current_node 在允许范围内 -->
            <if test="waiverCurrentNodeList != null and waiverCurrentNodeList.size() > 0">
                and (audit_type != 3 or current_node in
                <foreach collection="waiverCurrentNodeList" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
                )
            </if>
            and id <![CDATA[<]]> #{id} limit 1
        </where>
    </sql>


