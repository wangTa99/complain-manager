                vehicle_repaired,
            </if>
            <if test="mediaInfo != null">
                media_info,
            </if>
            <if test="currentNode != null">
                current_node,
            </if>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="complaintNo != null">
                #{complaintNo,jdbcType=VARCHAR},
            </if>
            <if test="vid != null">
                #{vid,jdbcType=VARCHAR},
            </if>
            <if test="carNo != null">
                #{carNo,jdbcType=VARCHAR},
            </if>
            <if test="orgId != null">
