        <result property="mediaInfo" column="media_info" jdbcType="INTEGER"/>
        <result property="currentNode" column="current_node" jdbcType="INTEGER"/>
    </resultMap>

    <sql id="Base_Column_List">
        au.id,au.complaint_no,au.vid,
        au.car_no,au.org_id,au.org_name,au.zone_id,au.little_zone_id,
        au.contact_name_c,au.contact_phone_c,au.apply_content,
        au.audit_type,au.audit_status,au.audit_mid,
        au.create_mid,au.create_time,au.update_time,
        au.audit_comment,au.contact_phone_md5,
        au.user_agreement,au.vehicle_repaired,au.media_info,
        au.current_node
    </sql>

    <select id="selectPageByParam"
            parameterType="com.wt.complaint.manage.domain.api.service.parameter.in.approve.ComplaintAuditListSoIn"
            resultType="com.wt.complaint.manage.infrastructure.model.ComplaintAuditDO">
        select
        <include refid="Base_Column_List"/>
        from complaint_audit au join complaint_order co on au.complaint_no = co.complaint_no
        <include refid="selectPageByParamCondition"/>
        order by au.id desc
    </select>

    <sql id="selectPageByParamCondition">
        <where>
            <if test="auditStatusList != null and auditStatusList.size()>0">
                AND au.audit_status IN
                <foreach collection="auditStatusList" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="auditTypeList != null and auditTypeList.size()>0">
                AND au.audit_type IN
                <foreach collection="auditTypeList" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="complaintNo != null and complaintNo != ''">
                AND au.complaint_no = #{complaintNo}
            </if>
            <if test="orgIdList != null and orgIdList.size() > 0">
                AND au.org_id IN
                <foreach collection="orgIdList" item="orgId" open="(" separator="," close=")">
                    #{orgId}
                </foreach>
            </if>
            <if test="contactPhoneMd5 != null and contactPhoneMd5 != ''">
                AND au.contact_phone_md5 = #{contactPhoneMd5}
            </if>
            <if test="carNo != null and carNo != ''">
                AND au.car_no = #{carNo}
            </if>
            <if test="vid != null and vid != ''">
                AND au.vid = #{vid}
            </if>
            <if test="createTimeStart != null and createTimeStart != ''">
                AND au.create_time <![CDATA[>=]]> #{createTimeStart}
            </if>
            <if test="createTimeEnd != null and createTimeEnd != ''">
                AND au.create_time <![CDATA[<=]]> #{createTimeEnd}
            </if>
            <if test="auditMid != null and auditMid != ''">
                AND au.audit_mid = #{auditMid}
            </if>
            <if test="zoneIdList != null and zoneIdList.size() > 0">
                AND au.zone_id IN
                <foreach collection="zoneIdList" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="littleZoneIdList != null and littleZoneIdList.size() > 0">
                AND au.little_zone_id IN
                <foreach collection="littleZoneIdList" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="testTag != null">
                AND co.test_tag = #{testTag,jdbcType=INTEGER}
            </if>
        </where>
    </sql>
